<odoo>
    <template id="report_saleorder_document_inherit" inherit_id="sale.report_saleorder_document">
        <xpath expr="//div[@id='informations']" position="after">
            <div class="row mt-4 mb-4" id="artline_custom_field">
                <div class="col-12">
                    <t t-if="doc.new_field">
                        <strong>New Field:</strong>
                        <span t-field="doc.new_field"/>
                    </t>
                    <t t-else="">
                        <span class="text-danger fw-bold">Поле New Field пустое!!!</span>
                    </t>
                </div>
            </div>
        </xpath>
    </template>
</odoo>