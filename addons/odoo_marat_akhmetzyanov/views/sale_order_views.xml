<odoo>
    <record id="view_order_form_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.artline</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="goods_issuer_id" options="{'no_create': True, 'no_open': True}"/>
            </xpath>

            <xpath expr="//group[@name='order_details']" position="inside">
                <field name="last_generated_value" invisible="1" force_save="1"/>
                <field name="is_new_field_manual" invisible="1" force_save="1"/>
                <field name="new_field"
                       readonly="state == 'sent'"
                       invisible="state == 'sale'"/>
            </xpath>
        </field>
    </record>
</odoo>